# Tailscale IP or MagicDNS name of the MASTER machine
MASTER_HOST=100.x.y.1

# Agent identity and advertised capacity
AGENT_ID=agent-remote-1
AGENT_CPU_CORES=4
AGENT_MEMORY_MB=8192

# Token generated in the dashboard (Admin > Agent Tokens > New Token)
AGENT_REGISTRATION_TOKEN=cb_at_<token-from-dashboard>
