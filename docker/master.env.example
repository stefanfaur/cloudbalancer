# Tailscale IP or MagicDNS name of this (master) machine
MASTER_HOST=100.x.y.1

# Kafka SASL credentials (REMOTE listener). Pick strong values.
KAFKA_ADMIN_PASSWORD=
KAFKA_AGENT_PASSWORD=

# JWT signing secret shared by dispatcher and metrics-aggregator
# (base64, >= 32 bytes; e.g. `openssl rand -base64 48`)
JWT_SECRET=
