# === Agent Identity ===
AGENT_ID=agent-remote-1
AGENT_CPU_CORES=4
AGENT_MEMORY_MB=8192

# === Registration ===
# Token generated in the dashboard UI (Admin > Agent Tokens > New Token).
# The agent sends this token to the dispatcher to receive Kafka credentials.
AGENT_REGISTRATION_TOKEN=cb_at_<token-from-dashboard>
DISPATCHER_URL=https://cloudbalancer.example.com

# === Worker Image ===
DOCKER_WORKER_IMAGE=git.faur.sh/stefanfaur/cloudbalancer-worker:latest
